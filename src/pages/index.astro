---
// Landing page (D-04/D-18) — a deliberate first impression: a single-focal-point
// hero (the accent CTA is the only accent fill on the page), an auto-generated
// chapters section from the collection, and the exam "coming soon" entry.
import { getCollection } from 'astro:content';

import Layout from '../components/Layout.astro';

import { sortChapters, type ChapterMeta } from '../lib/chapters';

import { joinBase } from '../lib/withBase';

const entries = await getCollection('chapters');

const metas: ChapterMeta[] = entries.map((entry) => ({
  number: entry.data.number,

  slug: entry.id,

  title: entry.data.title,
}));

const ordered = sortChapters(metas);

const bySlug = new Map(entries.map((entry) => [entry.id, entry]));

const firstChapter = ordered[0];

const browseHref = firstChapter
  ? joinBase(import.meta.env.BASE_URL, `chapters/${firstChapter.slug}`)
  : joinBase(import.meta.env.BASE_URL, '');

const examHref = joinBase(import.meta.env.BASE_URL, 'exam');

const pad = (n: number) => String(n).padStart(2, '0');
---

<Layout title="OS-self-study — Interactive CE357 Operating Systems notes">
  <section class="hero">
    <p class="eyebrow reveal" style="--i: 0">CE357 · Operating Systems · GJU</p>

    <h1 class="reveal" style="--i: 1">Operating systems, made to actually click.</h1>

    <p class="hero__tagline reveal" style="--i: 2">
      Interactive CE357 Operating Systems study notes &amp; simulations.
    </p>

    <div class="hero__actions reveal" style="--i: 3">
      <a class="cta" href={browseHref}>
        Browse chapters

        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>

      <span class="hero__hint">Built chapter by chapter from the lecture slides.</span>
    </div>
  </section>

  <section class="chapters reveal" style="--i: 4" aria-labelledby="chapters-heading">
    <div class="section-head">
      <p class="eyebrow" id="chapters-heading">Chapters</p>

      <span class="section-count">{ordered.length} available</span>
    </div>

    <ul class="chapter-grid">
      {
        ordered.map((chapter) => {
          const entry = bySlug.get(chapter.slug);

          return (
            <li>
              <a class="card" href={joinBase(import.meta.env.BASE_URL, `chapters/${chapter.slug}`)}>
                <span class="card__num eyebrow">{pad(chapter.number)}</span>

                <span class="card__body">
                  <span class="card__title">{chapter.title}</span>

                  {entry?.data.summary && <span class="card__summary">{entry.data.summary}</span>}
                </span>

                <svg
                  class="card__arrow"
                  viewBox="0 0 24 24"
                  width="18"
                  height="18"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>

  <section class="exam reveal" style="--i: 5">
    <a class="exam-card" href={examHref}>
      <span class="exam-card__text">
        <span class="eyebrow">Exam mode</span>

        <span class="exam-card__title">Practice questions &amp; timed exams</span>
      </span>

      <span class="soon-badge">Soon</span>
    </a>
  </section>
</Layout>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;

    margin: var(--space-md) 0 var(--space-3xl);

    padding: var(--space-2xl) var(--space-lg) var(--space-3xl);

    border: 1px solid var(--color-border);

    border-radius: var(--radius-lg);

    background:
      radial-gradient(120% 90% at 12% 0%, var(--color-accent-wash) 0%, transparent 60%),
      radial-gradient(var(--dot-grid) 1px, transparent 1px);

    background-size:
      auto,
      18px 18px;

    overflow: hidden;
  }

  .hero h1 {
    margin: var(--space-sm) 0 var(--space-md);

    max-width: 16ch;
  }

  .hero__tagline {
    max-width: 44ch;

    color: var(--color-text-muted);

    font-size: var(--font-size-body);

    margin: 0;
  }

  .hero__actions {
    display: flex;

    flex-wrap: wrap;

    align-items: center;

    gap: var(--space-md);

    margin-top: var(--space-xl);
  }

  .hero__hint {
    font-size: var(--font-size-label);

    color: var(--color-text-muted);
  }

  /* The single accent focal point on the page (reserved-for item 2). */
  .cta {
    display: inline-flex;

    align-items: center;

    gap: var(--space-sm);

    padding: 0 var(--space-lg);

    height: 46px;

    border-radius: var(--radius-md);

    background: var(--color-accent);

    color: #ffffff;

    font-weight: var(--font-weight-semibold);

    text-decoration: none;

    box-shadow: 0 6px 18px -6px color-mix(in srgb, var(--color-accent) 70%, transparent);

    transition:
      transform 0.15s ease,
      background 0.15s ease,
      box-shadow 0.15s ease;
  }

  .cta:hover {
    background: var(--color-accent-hover);

    transform: translateY(-1px);

    box-shadow: 0 10px 24px -6px color-mix(in srgb, var(--color-accent) 70%, transparent);
  }

  .cta svg {
    transition: transform 0.15s ease;
  }

  .cta:hover svg {
    transform: translateX(3px);
  }

  /* ---- Section heading ---- */
  .section-head {
    display: flex;

    align-items: baseline;

    justify-content: space-between;

    padding-bottom: var(--space-sm);

    margin-bottom: var(--space-md);

    border-bottom: 1px solid var(--color-border);
  }

  .section-count {
    font-size: var(--font-size-label);

    color: var(--color-text-muted);
  }

  /* ---- Chapter cards ---- */
  .chapter-grid {
    list-style: none;

    margin: 0 0 var(--space-3xl);

    padding: 0;

    display: grid;

    gap: var(--space-sm);
  }

  .card {
    display: grid;

    grid-template-columns: auto 1fr auto;

    align-items: center;

    gap: var(--space-md);

    padding: var(--space-md);

    border: 1px solid var(--color-border);

    border-radius: var(--radius-md);

    background: var(--color-surface-raised);

    color: var(--color-text);

    text-decoration: none;

    transition:
      transform 0.15s ease,
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .card:hover {
    transform: translateY(-2px);

    border-color: color-mix(in srgb, var(--color-text) 35%, var(--color-border));

    box-shadow: var(--shadow-md);
  }

  .card__num {
    align-self: start;

    padding: var(--space-xs) var(--space-sm);

    border-radius: var(--radius-sm);

    background: var(--color-surface);

    color: var(--color-text-muted);
  }

  .card__body {
    display: flex;

    flex-direction: column;

    gap: 2px;

    min-width: 0;
  }

  .card__title {
    font-weight: var(--font-weight-semibold);
  }

  .card__summary {
    font-size: var(--font-size-label);

    line-height: var(--line-height-snug);

    color: var(--color-text-muted);
  }

  .card__arrow {
    color: var(--color-text-muted);

    transition:
      transform 0.15s ease,
      color 0.15s ease;
  }

  .card:hover .card__arrow {
    color: var(--color-text);

    transform: translateX(3px);
  }

  /* ---- Exam entry ---- */
  .exam-card {
    display: flex;

    align-items: center;

    justify-content: space-between;

    gap: var(--space-md);

    padding: var(--space-md) var(--space-lg);

    border: 1px dashed var(--color-border);

    border-radius: var(--radius-md);

    background: transparent;

    color: var(--color-text);

    text-decoration: none;

    transition: border-color 0.15s ease;
  }

  .exam-card:hover {
    border-color: color-mix(in srgb, var(--color-text) 30%, var(--color-border));
  }

  .exam-card__text {
    display: flex;

    flex-direction: column;

    gap: 2px;
  }

  .exam-card__title {
    color: var(--color-text-muted);
  }

  .soon-badge {
    font-family: var(--font-mono);

    font-size: var(--font-size-micro);

    font-weight: var(--font-weight-semibold);

    letter-spacing: var(--tracking-caps);

    text-transform: uppercase;

    color: var(--color-text-muted);

    padding: var(--space-xs) var(--space-sm);

    border: 1px solid var(--color-border);

    border-radius: 999px;
  }

  /* ---- Staggered load-in (disabled under prefers-reduced-motion via tokens.css) ---- */
  .reveal {
    opacity: 0;

    animation: reveal-up 0.5s ease forwards;

    animation-delay: calc(var(--i) * 70ms);
  }

  @keyframes reveal-up {
    from {
      opacity: 0;

      transform: translateY(8px);
    }

    to {
      opacity: 1;

      transform: none;
    }
  }
</style>
