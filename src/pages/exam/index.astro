---
// Exam "coming soon" page (D-06) — a real page, not a dead link, so the
// Home/Chapters/Exam information architecture is locked before the exam
// engine exists (Phase 3) and the nav shape never shifts under visitors.
// Styled as an intentional empty state (D-01), never a broken placeholder.
import Layout from '../../components/Layout.astro';

import { joinBase } from '../../lib/withBase';

const chaptersHref = joinBase(import.meta.env.BASE_URL, 'chapters/example');
---

<Layout title="Exam — OS-self-study">
  <div class="empty-state">
    <h1>Exam mode is coming soon</h1>

    <p>
      Practice questions and timed exams unlock once Chapter 1 is complete. Browse the chapters in
      the meantime.
    </p>

    <a class="cta" href={chaptersHref}>Browse chapters</a>
  </div>
</Layout>

<style>
  .empty-state {
    display: flex;

    flex-direction: column;

    align-items: flex-start;

    gap: var(--space-md);

    max-width: 480px;

    margin: var(--space-3xl) auto;
  }

  .empty-state h1 {
    margin: 0;

    color: var(--color-text);

    font-size: var(--font-size-display);

    font-weight: var(--font-weight-semibold);

    line-height: 1.15;
  }

  .empty-state p {
    margin: 0;

    color: var(--color-text-muted);

    font-size: var(--font-size-body);

    line-height: 1.5;
  }

  .cta {
    display: inline-block;

    margin-top: var(--space-sm);

    padding: var(--space-sm) var(--space-lg);

    border-radius: 4px;

    background: var(--color-accent);

    color: var(--color-bg);

    font-weight: var(--font-weight-semibold);

    text-decoration: none;
  }

  .cta:hover {
    background: var(--color-accent-hover);
  }
</style>
