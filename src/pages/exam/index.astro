---
// Exam mode (D-06). Loads the Chapter 1 question bank from the `questions`
// collection and hands it to the QuizRunner island. client:only="svelte" because
// the runner reads/writes localStorage (resume + last score) — server-rendering a
// progress UI that can only be correct on the client would flash wrong content.
import Layout from '../../components/Layout.astro';

import QuizRunner from '../../widgets/exam/QuizRunner.svelte';

import { getCollection } from 'astro:content';

import { joinBase } from '../../lib/withBase';

const CHAPTER = 'introduction';

const all = await getCollection('questions');

// Filter to this chapter and strip the collection reference — the island only
// needs the plain question fields, serialized across the island boundary.
const questions = all
  .filter((entry) => entry.data.chapter.id === CHAPTER)
  .map((entry) => ({
    id: entry.data.id,

    topic: entry.data.topic,

    type: entry.data.type,

    difficulty: entry.data.difficulty,

    prompt: entry.data.prompt,

    choices: entry.data.choices ?? null,

    answer: entry.data.answer,

    solution: entry.data.solution,

    source: entry.data.source,
  }))
  .sort((a, b) => a.id.localeCompare(b.id));

const chaptersHref = joinBase(import.meta.env.BASE_URL, `chapters/${CHAPTER}`);
---

<Layout title="Exam mode — OS-self-study">
  <div class="exam-page">
    {
      questions.length > 0 ? (
        <QuizRunner client:only="svelte" questions={questions} chapter={CHAPTER} />
      ) : (
        <div class="empty-state">
          <h1>No questions yet</h1>

          <p>
            The exam bank fills up as each chapter lands. Browse the chapters in the meantime.
          </p>

          <a class="cta" href={chaptersHref}>Browse chapters</a>
        </div>
      )
    }
  </div>
</Layout>

<style>
  .exam-page {
    margin: var(--space-md) 0 var(--space-3xl);
  }

  .empty-state {
    display: flex;

    flex-direction: column;

    align-items: flex-start;

    gap: var(--space-md);

    max-width: 480px;

    margin: var(--space-3xl) auto;
  }

  .empty-state h1 {
    margin: 0;

    font-size: var(--font-size-display);
  }

  .empty-state p {
    margin: 0;

    color: var(--color-text-muted);

    line-height: var(--line-height-relaxed);
  }

  .cta {
    display: inline-block;

    margin-top: var(--space-sm);

    padding: var(--space-sm) var(--space-lg);

    border-radius: var(--radius-md);

    background: var(--color-accent);

    color: #ffffff;

    font-weight: var(--font-weight-semibold);

    text-decoration: none;
  }

  .cta:hover {
    background: var(--color-accent-hover);
  }
</style>
