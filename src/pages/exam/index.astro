---
// Exam mode (D-06). Loads every chapter's question bank from the `questions`
// collection, groups the questions by chapter, and hands the groups to the
// ExamShell island — a chapter switcher wrapping the per-chapter QuizRunner.
// client:only="svelte" because the runner reads/writes localStorage (resume +
// last score) — server-rendering a progress UI that can only be correct on the
// client would flash wrong content.
import Layout from '../../components/Layout.astro';

import ExamShell from '../../widgets/exam/ExamShell.svelte';

import { getCollection } from 'astro:content';

import { joinBase } from '../../lib/withBase';

const [questionEntries, chapterEntries] = await Promise.all([
  getCollection('questions'),

  getCollection('chapters'),
]);

// number + title per chapter slug, so each group can label and order itself.
const chapterMeta = new Map(
  chapterEntries.map((entry) => [entry.id, { number: entry.data.number, title: entry.data.title }]),
);

// The plain question shape the island consumes (no collection reference).
type IslandQuestion = {
  id: string;

  topic: string;

  type: string;

  difficulty: string;

  prompt: string;

  choices: string[] | null;

  answer: number | string;

  solution: string;

  source: string;
};

// Group questions by their chapter slug, stripping the collection reference —
// the island only needs the plain question fields, serialized across the boundary.
const byChapter = new Map<string, IslandQuestion[]>();

for (const entry of questionEntries) {

  const slug = entry.data.chapter.id;

  const list = byChapter.get(slug) ?? [];

  list.push({
    id: entry.data.id,

    topic: entry.data.topic,

    type: entry.data.type,

    difficulty: entry.data.difficulty,

    prompt: entry.data.prompt,

    choices: entry.data.choices ?? null,

    answer: entry.data.answer,

    solution: entry.data.solution,

    source: entry.data.source,
  });

  byChapter.set(slug, list);
}

// One group per chapter, questions sorted by id, groups sorted by chapter number.
const groups = [...byChapter.entries()]
  .map(([slug, questions]) => ({
    slug,

    number: chapterMeta.get(slug)?.number ?? Number.MAX_SAFE_INTEGER,

    title: chapterMeta.get(slug)?.title ?? slug,

    questions: questions.sort((a, b) => a.id.localeCompare(b.id)),
  }))
  .sort((a, b) => a.number - b.number);

const chaptersHref = joinBase(import.meta.env.BASE_URL, 'chapters/introduction');
---

<Layout title="Exam mode — OS-self-study">
  <div class="exam-page">
    {
      groups.length > 0 ? (
        <ExamShell client:only="svelte" groups={groups} />
      ) : (
        <div class="empty-state">
          <h1>No questions yet</h1>

          <p>
            The exam bank fills up as each chapter lands. Browse the chapters in the meantime.
          </p>

          <a class="cta" href={chaptersHref}>Browse chapters</a>
        </div>
      )
    }
  </div>
</Layout>

<style>
  .exam-page {
    margin: var(--space-md) 0 var(--space-3xl);
  }

  .empty-state {
    display: flex;

    flex-direction: column;

    align-items: flex-start;

    gap: var(--space-md);

    max-width: 480px;

    margin: var(--space-3xl) auto;
  }

  .empty-state h1 {
    margin: 0;

    font-size: var(--font-size-display);
  }

  .empty-state p {
    margin: 0;

    color: var(--color-text-muted);

    line-height: var(--line-height-relaxed);
  }

  .cta {
    display: inline-block;

    margin-top: var(--space-sm);

    padding: var(--space-sm) var(--space-lg);

    border-radius: var(--radius-md);

    background: var(--color-accent);

    color: #ffffff;

    font-weight: var(--font-weight-semibold);

    text-decoration: none;
  }

  .cta:hover {
    background: var(--color-accent-hover);
  }
</style>
