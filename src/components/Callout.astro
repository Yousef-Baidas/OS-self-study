---
// Definition / key-point / warning box (D-08's annotated-chapter Callout).
// Locked component — later chapter phases use this, never re-create it.
// Each variant carries a mono-caps label + Lucide-style glyph and a restrained
// tinted surface; note = accent, key = strong-neutral, warning = amber.
interface Props {
  type: 'note' | 'key' | 'warning';
}

const { type } = Astro.props;

const LABEL = {
  note: 'Note',

  key: 'Key idea',

  warning: 'Warning',
};
---

<div class:list={['callout', `callout--${type}`]}>
  <div class="callout__head">
    <span class="callout__icon" aria-hidden="true">
      {
        type === 'note' && (
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10" />
            <path d="M12 16v-4M12 8h.01" />
          </svg>
        )
      }
      {
        type === 'key' && (
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M9 18h6M10 22h4" />
            <path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.6 4.6 0 0 1 8.91 14" />
          </svg>
        )
      }
      {
        type === 'warning' && (
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
            <path d="M12 9v4M12 17h.01" />
          </svg>
        )
      }
    </span>

    <span class="eyebrow callout__label">{LABEL[type]}</span>
  </div>

  <div class="callout__body">
    <slot />
  </div>
</div>

<style>
  .callout {
    margin: var(--space-lg) 0;

    padding: var(--space-md) var(--space-md) var(--space-sm);

    border: 1px solid var(--color-border);

    border-left-width: 3px;

    border-radius: var(--radius-md);

    background: var(--color-surface);

    color: var(--color-text);
  }

  .callout__head {
    display: flex;

    align-items: center;

    gap: var(--space-sm);

    margin-bottom: var(--space-xs);
  }

  .callout__icon {
    display: inline-flex;
  }

  .callout__icon svg {
    width: 18px;

    height: 18px;
  }

  .callout__label {
    color: inherit;
  }

  /* Body inherits prose spacing but drops the trailing paragraph margin. */
  .callout__body :global(:last-child) {
    margin-bottom: 0;
  }

  .callout--note {
    border-left-color: var(--color-accent);

    background: var(--color-accent-wash);
  }

  .callout--note .callout__head {
    color: var(--color-accent);
  }

  .callout--key {
    border-left-color: var(--color-text);

    background: var(--color-surface-raised);
  }

  .callout--key .callout__head {
    color: var(--color-text);
  }

  .callout--warning {
    border-left-color: var(--color-warning);

    background: var(--color-warning-wash);
  }

  .callout--warning .callout__head {
    color: var(--color-warning);
  }
</style>
