---
// Hand-rolled inline SVG icon — Lucide-style grammar (24x24 viewBox, ~2px
// stroke, round linecap/linejoin, no fill). No npm icon package dependency
// per UI-SPEC's Design System "Icon library" row. Hamburger/menu glyph, kept
// alongside the other nav icons this plan adds for design-system parity —
// the bottom-nav's Chapters tab uses BookOpen (reused from Plan 02) per this
// plan's own action spec, so this one has no call site yet in this plan.
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  {...Astro.props}
>
  <line x1="4" x2="20" y1="6" y2="6" />

  <line x1="4" x2="20" y1="12" y2="12" />

  <line x1="4" x2="20" y1="18" y2="18" />
</svg>
