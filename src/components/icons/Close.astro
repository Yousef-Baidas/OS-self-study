---
// Hand-rolled inline SVG icon — Lucide-style grammar (24x24 viewBox, ~2px
// stroke, round linecap/linejoin, no fill). No npm icon package dependency
// per UI-SPEC's Design System "Icon library" row. Used for the mobile
// chapters drawer's close button.
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  {...Astro.props}
>
  <path d="M18 6 6 18" />

  <path d="m6 6 12 12" />
</svg>
