---
// Page shell — locked location (D-03/UI-SPEC), inherited by every later phase.
// Plan 02 fills the `sidebar` slot (persistent desktop nav, see the `.shell`
// flex wrapper below); Plan 03 fills `bottom-nav` with BottomNav.astro (a
// slot default, so a page could still override it) and adds the mobile
// chapters drawer (Sidebar's "drawer" variant) as permanent page chrome so
// D-14 works from any page, not only chapter pages. The theme toggle region
// is reserved but unwired until Plan 04 adds the blocking inline <head>
// script (D-17). Do not add that script here yet.
import '../styles/global.css';

import BottomNav from './BottomNav.astro';

import Sidebar from './Sidebar.astro';

interface Props {
  title?: string;

  currentSlug?: string;
}

const { title = 'OS-self-study', currentSlug } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
  </head>

  <body>
    <header class="site-header">
      <span class="site-title">OS-self-study</span>

      <div class="theme-toggle-slot" aria-hidden="true"></div>
    </header>

    <div class="shell">
      <slot name="sidebar" />

      <main>
        <slot />
      </main>
    </div>

    <slot name="bottom-nav">
      <BottomNav />
    </slot>

    <Sidebar variant="drawer" currentSlug={currentSlug} />

    <footer class="site-footer">
      <p>OS-self-study — CE357 Operating Systems study notes.</p>
    </footer>

    <style>
      .site-header {
        position: sticky;

        top: 0;

        display: flex;

        align-items: center;

        justify-content: space-between;

        height: 56px;

        padding: 0 var(--space-md);

        background: var(--color-surface);

        border-bottom: 1px solid var(--color-border);
      }

      .site-title {
        font-weight: 600;

        color: var(--color-text);
      }

      /* Reserved 44x44 hit-target region for Plan 04's theme toggle button. */
      .theme-toggle-slot {
        width: 44px;

        height: 44px;
      }

      .shell {
        display: flex;

        align-items: flex-start;
      }

      main {
        flex: 1;

        min-width: 0;

        max-width: 720px;

        margin: 0 auto;

        padding: var(--space-lg) var(--space-md);
      }

      .site-footer {
        padding: var(--space-lg) var(--space-md);

        color: var(--color-text-muted);

        border-top: 1px solid var(--color-border);
      }
    </style>
  </body>
</html>
