---
// Base-path-safe captioned figure (PLAT-03, D-08). Every internal asset path
// MUST go through joinBase — a hardcoded absolute src 404s on the live
// /OS-self-study/ GitHub Pages base path even though it works in local dev.
import { joinBase } from '../lib/withBase';

interface Props {
  src: string;
  alt: string;
  caption: string;
}

const { src, alt, caption } = Astro.props;

const url = joinBase(import.meta.env.BASE_URL, src);
---

<figure>
  <img src={url} alt={alt} />

  <figcaption>{caption}</figcaption>
</figure>

<style>
  figure {
    margin: var(--space-lg) 0;
  }

  img {
    max-width: 100%;

    display: block;

    border: 1px solid var(--color-border);

    border-radius: 4px;
  }

  figcaption {
    margin-top: var(--space-xs);

    color: var(--color-text-muted);

    font-size: 14px;
  }
</style>
