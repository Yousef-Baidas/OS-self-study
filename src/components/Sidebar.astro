---
// Auto-generated chapter nav (NAV-01) — desktop persistent 260px left column,
// filled into Layout.astro's `sidebar` slot. In `variant="drawer"` this same
// component IS the mobile chapters drawer (D-14): a hand-rolled WAI-ARIA APG
// modal dialog (RESEARCH Pattern 5) wrapping the identical chapter list, so
// the list markup/styling/data pipeline stays single-sourced rather than a
// second component re-deriving it.
//
// Sourced from getCollection('chapters') -> sortChapters (never raw collection
// iteration order, which glob() does not guarantee matches frontmatter number).
// Every link is base-path-safe via joinBase — never a hardcoded "/chapters/..."
// literal, so nothing 404s under the GitHub Pages base path.
import { getCollection } from 'astro:content';

import { sortChapters, type ChapterMeta } from '../lib/chapters';

import { joinBase } from '../lib/withBase';

import BookOpen from './icons/BookOpen.astro';

import Close from './icons/Close.astro';

interface Props {
  currentSlug?: string;

  variant?: 'sidebar' | 'drawer';
}

const { currentSlug, variant = 'sidebar' } = Astro.props;

const isDrawer = variant === 'drawer';

const chapterEntries = await getCollection('chapters');

const chapterMetas: ChapterMeta[] = chapterEntries.map((entry) => ({
  number: entry.data.number,

  slug: entry.id,

  title: entry.data.title,
}));

const chapters = sortChapters(chapterMetas);
---

{
  isDrawer ? (
    <>
      <div
        id="chapter-drawer"
        class="drawer-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="chapter-drawer-title"
        data-open="false"
      >
        <div class="drawer-header">
          <h2 id="chapter-drawer-title" class="drawer-title">
            Chapters
          </h2>

          <button type="button" class="drawer-close" aria-label="Close chapter menu" data-close>
            <Close width="20" height="20" />
          </button>
        </div>

        <ul class="sidebar-list">
          {chapters.map((chapter) => {

            const isActive = chapter.slug === currentSlug;

            return (
              <li>
                <a
                  href={joinBase(import.meta.env.BASE_URL, `chapters/${chapter.slug}`)}
                  class:list={['sidebar-link', { 'sidebar-link--active': isActive }]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {chapter.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <div class="drawer-scrim" data-scrim data-open="false" />

      <script>
        // Drawer open/close + focus-trap wiring (RESEARCH Pattern 5) — a
        // regular script, not a Svelte island, per the "no client:* outside
        // components that need actual JS state" convention. Connects to the
        // bottom-nav's Chapters tab purely via DOM id, so BottomNav.astro
        // and this drawer stay decoupled (no prop/import coupling needed).
        import { getFocusableElements, nextTrapIndex } from '../lib/focus-trap';

        const drawer = document.getElementById('chapter-drawer');

        const scrim = document.querySelector<HTMLElement>('[data-scrim]');

        const openBtn = document.getElementById('chapters-tab');

        if (drawer && scrim && openBtn) {

          let lastFocused: HTMLElement | null = null;

          const setOpen = (open: boolean) => {

            drawer.dataset.open = open ? 'true' : 'false';

            scrim.dataset.open = open ? 'true' : 'false';
          };

          const openDrawer = () => {

            lastFocused = document.activeElement as HTMLElement;

            setOpen(true);

            getFocusableElements(drawer)[0]?.focus();
          };

          const closeDrawer = () => {

            setOpen(false);

            lastFocused?.focus();
          };

          drawer.addEventListener('keydown', (event) => {

            if (event.key === 'Escape') {

              closeDrawer();

              return;
            }

            if (event.key !== 'Tab') return;

            const focusable = getFocusableElements(drawer);

            if (focusable.length === 0) return;

            event.preventDefault();

            const currentIndex = focusable.indexOf(document.activeElement as HTMLElement);

            const activeIndex = currentIndex === -1 ? 0 : currentIndex;

            const nextIndex = nextTrapIndex(focusable.length, activeIndex, event.shiftKey);

            focusable[nextIndex]?.focus();
          });

          openBtn.addEventListener('click', openDrawer);

          scrim.addEventListener('click', closeDrawer);

          drawer.querySelector<HTMLElement>('[data-close]')?.addEventListener('click', closeDrawer);
        }
      </script>
    </>
  ) : (
    <nav aria-label="Chapters" class="sidebar">
      <div class="sidebar-heading">
        <BookOpen width="18" height="18" />

        <span>Chapters</span>
      </div>

      <ul class="sidebar-list">
        {chapters.map((chapter) => {

          const isActive = chapter.slug === currentSlug;

          return (
            <li>
              <a
                href={joinBase(import.meta.env.BASE_URL, `chapters/${chapter.slug}`)}
                class:list={['sidebar-link', { 'sidebar-link--active': isActive }]}
                aria-current={isActive ? 'page' : undefined}
              >
                {chapter.title}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  )
}

<style>
  .sidebar {
    display: none;
  }

  @media (min-width: 1024px) {

    .sidebar {
      display: block;

      width: 260px;

      flex-shrink: 0;

      padding: var(--space-lg) var(--space-md);

      background: var(--color-surface);

      border-right: 1px solid var(--color-border);
    }
  }

  .sidebar-heading {
    display: flex;

    align-items: center;

    gap: var(--space-xs);

    margin-bottom: var(--space-md);

    color: var(--color-text-muted);

    font-size: var(--font-size-label);

    font-weight: var(--font-weight-semibold);

    text-transform: uppercase;

    letter-spacing: 0.04em;
  }

  .sidebar-list {
    margin: 0;

    padding: 0;

    list-style: none;
  }

  .sidebar-link {
    display: block;

    padding: var(--space-sm) var(--space-md);

    border-radius: var(--radius-sm);

    color: var(--color-text);

    font-size: var(--font-size-label);

    line-height: 1.4;

    text-decoration: none;

    transition:
      color 0.15s ease,
      background 0.15s ease;
  }

  .sidebar-link:hover {
    color: var(--color-accent-hover);

    background: var(--color-surface-raised);
  }

  /* Active chapter — a soft accent wash + accent text instead of a side stripe,
     which reads cleaner in the narrow rail and matches the warm palette. */
  .sidebar-link--active {
    background: var(--color-accent-wash);

    color: var(--color-accent);

    font-weight: var(--font-weight-semibold);
  }

  .sidebar-link--active:hover {
    background: var(--color-accent-wash-strong);
  }

  /* Mobile chapters drawer (D-14) — a separate class from .sidebar (not a
     variant of it) so the desktop-only display:none/block cascade above
     never has to be fought; the drawer's own visibility is entirely driven
     by [data-open], not by the --bp-desktop breakpoint on itself. */
  .drawer-panel {
    position: fixed;

    top: 0;

    left: 0;

    z-index: 60;

    display: flex;

    flex-direction: column;

    width: min(85vw, 320px);

    /* Progressive enhancement: dvh/svh override vh where supported so the
       drawer never over/under-shoots iOS Safari's dynamic toolbar (Pitfall 6). */
    height: 100vh;

    height: 100svh;

    height: 100dvh;

    padding: var(--space-lg) var(--space-md);

    background: var(--color-surface);

    border-right: 1px solid var(--color-border);

    overflow-y: auto;

    transform: translateX(-100%);

    /* visibility flips to hidden only after the close transition finishes,
       so a closed-but-off-screen drawer is removed from the tab order and
       the accessibility tree, not just visually hidden (Pitfall 7). */
    visibility: hidden;

    transition:
      transform 0.25s ease,
      visibility 0s linear 0.25s;
  }

  .drawer-panel[data-open='true'] {
    transform: translateX(0);

    visibility: visible;

    transition: transform 0.25s ease;
  }

  @media (min-width: 1024px) {

    .drawer-panel {
      display: none;
    }
  }

  .drawer-header {
    display: flex;

    align-items: center;

    justify-content: space-between;

    margin-bottom: var(--space-md);
  }

  .drawer-title {
    margin: 0;

    color: var(--color-text);

    font-size: var(--font-size-heading);

    font-weight: var(--font-weight-semibold);
  }

  .drawer-close {
    display: flex;

    align-items: center;

    justify-content: center;

    min-width: 44px;

    min-height: 44px;

    padding: 0;

    border: none;

    border-radius: var(--radius-sm);

    background: transparent;

    color: var(--color-text);

    cursor: pointer;

    transition:
      background 0.15s ease,
      color 0.15s ease;
  }

  .drawer-close:hover {
    background: var(--color-surface-raised);

    color: var(--color-accent-hover);
  }

  .drawer-scrim {
    position: fixed;

    inset: 0;

    z-index: 55;

    background: var(--color-scrim);

    opacity: 0;

    pointer-events: none;

    transition: opacity 0.25s ease;
  }

  .drawer-scrim[data-open='true'] {
    opacity: 1;

    pointer-events: auto;
  }

  @media (min-width: 1024px) {

    .drawer-scrim {
      display: none;
    }
  }
</style>
