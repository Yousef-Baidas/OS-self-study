---
// Auto-generated chapter nav (NAV-01) — desktop persistent 260px left column,
// filled into Layout.astro's `sidebar` slot. This component's markup is also
// reused as the mobile drawer's content in Plan 03, so it stays self-contained
// (its own <nav>, its own styles) rather than assuming a desktop-only shell.
//
// Sourced from getCollection('chapters') -> sortChapters (never raw collection
// iteration order, which glob() does not guarantee matches frontmatter number).
// Every link is base-path-safe via joinBase — never a hardcoded "/chapters/..."
// literal, so nothing 404s under the GitHub Pages base path.
import { getCollection } from 'astro:content';

import { sortChapters, type ChapterMeta } from '../lib/chapters';

import { joinBase } from '../lib/withBase';

import BookOpen from './icons/BookOpen.astro';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const chapterEntries = await getCollection('chapters');

const chapterMetas: ChapterMeta[] = chapterEntries.map((entry) => ({
  number: entry.data.number,

  slug: entry.id,

  title: entry.data.title,
}));

const chapters = sortChapters(chapterMetas);
---

<nav aria-label="Chapters" class="sidebar">
  <div class="sidebar-heading">
    <BookOpen width="18" height="18" />

    <span>Chapters</span>
  </div>

  <ul class="sidebar-list">
    {
      chapters.map((chapter) => {

        const isActive = chapter.slug === currentSlug;

        return (
          <li>
            <a
              href={joinBase(import.meta.env.BASE_URL, `chapters/${chapter.slug}`)}
              class:list={['sidebar-link', { 'sidebar-link--active': isActive }]}
              aria-current={isActive ? 'page' : undefined}
            >
              {chapter.title}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<style>
  .sidebar {
    display: none;
  }

  @media (min-width: 1024px) {

    .sidebar {
      display: block;

      width: 260px;

      flex-shrink: 0;

      padding: var(--space-lg) var(--space-md);

      background: var(--color-surface);

      border-right: 1px solid var(--color-border);
    }
  }

  .sidebar-heading {
    display: flex;

    align-items: center;

    gap: var(--space-xs);

    margin-bottom: var(--space-md);

    color: var(--color-text-muted);

    font-size: var(--font-size-label);

    font-weight: var(--font-weight-semibold);

    text-transform: uppercase;

    letter-spacing: 0.04em;
  }

  .sidebar-list {
    margin: 0;

    padding: 0;

    list-style: none;
  }

  .sidebar-link {
    display: block;

    padding: var(--space-sm) var(--space-md);

    border-left: 2px solid transparent;

    color: var(--color-text);

    font-size: var(--font-size-label);

    line-height: 1.4;

    text-decoration: none;
  }

  .sidebar-link:hover {
    color: var(--color-accent-hover);

    background: var(--color-bg);
  }

  .sidebar-link--active {
    border-left-color: var(--color-accent);

    color: var(--color-accent);

    font-weight: var(--font-weight-semibold);
  }
</style>
